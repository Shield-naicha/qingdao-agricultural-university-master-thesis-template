% ---------- western font fallback ----------
% 英文字体按“Times New Roman -> Tinos -> TeX Gyre Termes”顺序回退，
% 以减少不同系统下因缺字库导致的编译失败。
\IfFontExistsTF{Times New Roman}
  {\newfontfamily\qauTimes{Times New Roman}}
  {\IfFontExistsTF{Tinos}
    {\newfontfamily\qauTimes{Tinos}}
    {\newfontfamily\qauTimes{TeX Gyre Termes}}}
\IfFontExistsTF{Monotype Corsiva}
  {\newfontfamily\qauCorsiva{Monotype Corsiva}}
  {\IfFontExistsTF{TeX Gyre Chorus}
    {\newfontfamily\qauCorsiva{TeX Gyre Chorus}}
    {\IfFontExistsTF{TeXGyreChorus}
      {\newfontfamily\qauCorsiva{TeXGyreChorus}}
      {\newfontfamily\qauCorsiva{Z003}}}}
